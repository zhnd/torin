# ============================================================================
# Torin — environment config
#
# Copy this file to `.env` and fill in real values. Required vars are
# checked by apps/server/src/infrastructure/env.ts at startup; missing
# or malformed values fail-fast with a clear error message.
#
# Anything starting with REPLACE_ME or similar placeholder is intentionally
# invalid so the server refuses to boot until you provide a real value.
# ============================================================================

# ── Runtime mode ──────────────────────────────────────────────────────
# One of: production | development | test. Required.
NODE_ENV=development

# ── HTTP / CORS ───────────────────────────────────────────────────────
# Server listen port. Optional; default 4000.
PORT=4000

# Comma-separated allowed CORS origins for the GraphQL API. Required.
# In production this MUST be the exact web origin(s); never `*`.
WEB_URL=http://localhost:3000

# ── Database (Prisma + better-auth) ───────────────────────────────────
# Postgres connection string. Required.
# Local dev (matches docker-compose default):
DATABASE_URL=postgres://torin:torin@localhost:5432/torin

# ── Authentication (better-auth) ──────────────────────────────────────
# Public URL the browser-side better-auth client posts to. Required.
BETTER_AUTH_URL=http://localhost:4000

# Server-side session signing secret. Required, min 32 chars.
# Generate per-deployment: `openssl rand -base64 48`
# NEVER commit a real value to git; never reuse across deployments.
BETTER_AUTH_SECRET=REPLACE_ME_run_openssl_rand_base64_48

# Optional: enable Google OAuth login. Both must be set together.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Credential encryption (project tokens) ────────────────────────────
# 32-byte key encoded as a 64-char hex string. Required.
# Generate per-deployment: `openssl rand -hex 32`
# WARNING: changing this key invalidates ALL existing encrypted
# credentials (project GitHub / cnb.cool tokens) — every project
# owner must re-enter their token via the UI.
CREDENTIALS_ENCRYPTION_KEY=REPLACE_ME_run_openssl_rand_hex_32

# ── Temporal (workflow orchestration) ─────────────────────────────────
# host:port. Required. Local dev (docker-compose default):
TEMPORAL_ADDRESS=localhost:7233

# ── Logging ───────────────────────────────────────────────────────────
# Pino level: trace | debug | info | warn | error | fatal.
# Optional; default info.
LOG_LEVEL=info

# ── Agent runtime (Claude Agent SDK) ──────────────────────────────────
# Override the default Claude model used by all agents.
# Optional; default claude-sonnet-4-6.
AGENT_MODEL=claude-sonnet-4-6

# Anthropic API key. Required for the agent SDK to authenticate
# unless ANTHROPIC_BASE_URL points at an alternative endpoint that
# uses ANTHROPIC_AUTH_TOKEN below.
# Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: point the SDK at an OpenAI-compatible third-party endpoint
# (e.g., a proxy serving Qwen / DeepSeek / your own model). When set,
# ANTHROPIC_AUTH_TOKEN is used instead of ANTHROPIC_API_KEY.
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=

# ── Workflow tuning ───────────────────────────────────────────────────
# When `true`, trivial-class resolutions skip the human review gate.
# Optional; default false.
TORIN_AUTO_APPROVE_TRIVIAL=false

# ── Sandbox (Docker) ──────────────────────────────────────────────────
# Base image used by sandbox builder containers. Build it once with:
#   pnpm sandbox:build-base
TORIN_SANDBOX_BASE_IMAGE=torin/sandbox-base:1

# Host filesystem directory used to serialize concurrent repo image
# builds across worker processes. Optional; default `$TMPDIR/torin/locks`.
# TORIN_LOCK_ROOT=

# Per-toolchain default versions used when a repo doesn't declare its
# own (no mise.toml / .tool-versions / .nvmrc / etc).
TORIN_DEFAULT_NODE_VERSION=22
TORIN_DEFAULT_PYTHON_VERSION=3.12
TORIN_DEFAULT_RUST_VERSION=stable
TORIN_DEFAULT_GO_VERSION=latest
TORIN_DEFAULT_BUN_VERSION=latest

# ── Web (NEXT_PUBLIC_*) ──────────────────────────────────────────────
# IMPORTANT: NEXT_PUBLIC_* values are baked into the client JS bundle
# at build time and shipped to the browser. NEVER put secrets here.

# GraphQL HTTP endpoint the web app fetches from.
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql

# GraphQL WebSocket endpoint for subscriptions. Optional;
# defaults to NEXT_PUBLIC_API_URL with http -> ws.
NEXT_PUBLIC_API_WS_URL=ws://localhost:4000/graphql

# Origin of the web app itself; used by the better-auth client.
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# Backend origin used by the Next.js rewrite that proxies /api/auth/*
# requests to the better-auth server. Same as the API host without
# the /graphql suffix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
