generator client {
  provider = "prisma-client"
  output   = "../src/__generated__/prisma"
}

generator pothos {
  provider          = "prisma-pothos-types"
  prismaUtils       = true
  generateDatamodel = true
  output            = "../src/__generated__/pothos-prisma-types.ts"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────

enum AuthMethod {
  NONE
  TOKEN
  SSH_KEY
}

enum AuthProvider {
  GITHUB
  GITLAB
  GITEA
  CNB
}

enum TaskType {
  ANALYZE_REPOSITORY
  RESOLVE_DEFECT
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskEventKind {
  STAGE
  REVIEW
}

enum TaskEventStatus {
  RUNNING
  AWAITING
  COMPLETED
  REJECTED
  FAILED
  SKIPPED
}

enum TaskStageKey {
  ANALYSIS
  REPRODUCE
  IMPLEMENT
  FILTER
  CRITIC
  PR
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum StageStatus {
  PENDING
  RUNNING
  AWAITING
  COMPLETED
  FAILED
  SKIPPED
}

enum AgentInvocationStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ── Auth (better-auth) ─────────────────────────────────────────

model User {
  id            String      @id
  name          String
  email         String
  emailVerified Boolean     @default(false)
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sessions      Session[]
  accounts      Account[]
  projects      Project[]
  tasks         Task[]
  taskReviews   TaskEvent[] @relation("decidedBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Projects ───────────────────────────────────────────────────

model Project {
  id                   String       @id @default(cuid())
  name                 String
  repositoryUrl        String
  authMethod           AuthMethod   @default(NONE)
  authProvider         AuthProvider @default(GITHUB)
  encryptedCredentials String?
  // Structured per-workflow config. Shape discriminated by key at read time.
  // e.g. { preview: { command, port, readyPattern } }
  workflowConfig       Json?
  // Legacy preview fields — superseded by workflowConfig.preview; kept
  // nullable for one release so running code can still read them.
  previewCommand       String?
  previewPort          Int?
  previewReadyPattern  String?
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                Task[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId])
  @@map("project")
}

// ── Tasks ──────────────────────────────────────────────────────
//
// Task is slim metadata only: who, what, when, lifecycle status. No per-stage
// state lives here — that's all in TaskEvent. The server resolver derives
// the display view (current stage, awaiting flag, stage list with attempts +
// reviews) from grouping events by stageKey.

model Task {
  id            String     @id @default(cuid())
  type          TaskType   @default(ANALYZE_REPOSITORY)
  status        TaskStatus @default(PENDING)

  // Original request payload for this task (e.g. {defectDescription}).
  input         Json

  // How the task was triggered: 'manual' | 'webhook' | 'cron' | ...
  triggerSource String     @default("manual")

  // Terminal-only error text (set when status → FAILED / CANCELLED).
  error         String?

  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Temporal workflow id, set after workflow.start. Unique because each
  // task corresponds to at most one running workflow.
  workflowId    String?    @unique

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  startedAt     DateTime?  // first transition into RUNNING
  completedAt   DateTime?  // first transition into a terminal status

  events        TaskEvent[]
  executions    WorkflowExecution[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("task")
}

// One row per (stage, attempt) for STAGE kind, or per (stage, attempt) of
// HITL submission for REVIEW kind. Self-contained — input/output captures
// what went in and came out so the row is debuggable in isolation.
//
// Lifecycle:
//   STAGE: RUNNING → (AWAITING) → COMPLETED | REJECTED | FAILED | SKIPPED
//   REVIEW: inserted at COMPLETED (the decision is the event)
//
// See plan: /Users/void/.claude/plans/cnb-cool-cnb-mellow-parnas.md
model TaskEvent {
  id            String          @id @default(cuid())
  taskId        String
  task          Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  kind          TaskEventKind
  stageKey      TaskStageKey
  attemptNumber Int             @default(1)

  status        TaskEventStatus @default(RUNNING)
  input         Json?
  output        Json?
  error         String?

  // Reviewer userId — non-null iff kind = REVIEW.
  decidedBy     String?
  decidedByUser User?           @relation("decidedBy", fields: [decidedBy], references: [id], onDelete: SetNull)

  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  durationMs       Int?

  // Phase 1 agent observability: each STAGE-kind event may have one or
  // more AgentInvocation rows attached (per-agent technical telemetry,
  // separate from the business-level event lifecycle above).
  agentInvocations AgentInvocation[]

  @@unique([taskId, kind, stageKey, attemptNumber])
  @@index([taskId, startedAt])
  @@index([taskId, status])
  @@map("task_event")
}

// ── Layer 0: Workflow registry ────────────────────────────────

model WorkflowDefinition {
  id          String          @id @default(cuid())
  kind        String          @unique
  displayName String
  version     Int             @default(1)
  stages      WorkflowStage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("workflow_definition")
}

model WorkflowStage {
  id                   String             @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  name                 String
  label                String
  order                Int
  allowsRetry          Boolean            @default(true)
  allowsHitl           Boolean            @default(false)
  config               Json?

  @@unique([workflowDefinitionId, name])
  @@index([workflowDefinitionId, order])
  @@map("workflow_stage")
}

// ── Layer 1: Execution telemetry (deferred — kept for trace work) ─────

model WorkflowExecution {
  id                 String           @id @default(cuid())
  taskId             String
  task               Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workflowKind       String
  workflowVersion    Int              @default(1)
  traceId            String           @unique
  temporalWorkflowId String?
  status             ExecutionStatus  @default(RUNNING)
  startedAt          DateTime         @default(now())
  endedAt            DateTime?
  durationMs         Int?
  stages             StageExecution[]
  retrospective      Retrospective?

  @@index([taskId])
  @@index([workflowKind, status])
  @@map("workflow_execution")
}

model StageExecution {
  id                  String             @id @default(cuid())
  workflowExecutionId String
  workflowExecution   WorkflowExecution  @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)
  stageName           String
  order               Int
  status              StageStatus        @default(PENDING)
  spanId              String             @unique
  parentSpanId        String
  startedAt           DateTime           @default(now())
  endedAt             DateTime?
  durationMs          Int?
  attempts            AttemptExecution[]

  @@index([workflowExecutionId, order])
  @@map("stage_execution")
}

model AttemptExecution {
  id               String            @id @default(cuid())
  stageExecutionId String
  stageExecution   StageExecution    @relation(fields: [stageExecutionId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  triggerKind      String
  triggerPayload   Json?
  spanId           String            @unique
  parentSpanId     String
  status           StageStatus       @default(RUNNING)
  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  durationMs       Int?
  invocations      AgentInvocation[]

  @@unique([stageExecutionId, attemptNumber])
  @@map("attempt_execution")
}

model AgentInvocation {
  id                 String                @id @default(cuid())
  // Phase 1 (event-model link): every agent run is anchored to its parent
  // STAGE TaskEvent. attemptExecutionId is left for legacy compatibility
  // with the (currently unused) lifecycle tier and is now nullable.
  taskEventId        String?
  taskEvent          TaskEvent?            @relation(fields: [taskEventId], references: [id], onDelete: Cascade)
  attemptExecutionId String?
  attemptExecution   AttemptExecution?     @relation(fields: [attemptExecutionId], references: [id], onDelete: Cascade)
  agentName          String
  model              String
  status             AgentInvocationStatus @default(RUNNING)
  errorText          String?
  spanId             String                @unique
  parentSpanId       String
  startedAt          DateTime              @default(now())
  endedAt            DateTime?
  durationMs         Int?
  totalCostUsd       Float?
  inputTokens        Int?
  outputTokens       Int?
  turns              AgentTurn[]
  toolCalls          ToolCall[]

  @@index([attemptExecutionId])
  @@index([taskEventId])
  @@map("agent_invocation")
}

model AgentTurn {
  id                String          @id @default(cuid())
  agentInvocationId String
  agentInvocation   AgentInvocation @relation(fields: [agentInvocationId], references: [id], onDelete: Cascade)
  turnIndex         Int
  role              String
  textContent       String?
  textTruncatedAt   Int?
  toolUseCount      Int             @default(0)
  inputTokens       Int?
  outputTokens      Int?
  startedAt         DateTime        @default(now())
  toolCalls         ToolCall[]

  @@unique([agentInvocationId, turnIndex])
  @@map("agent_turn")
}

model ToolCall {
  id                String          @id @default(cuid())
  agentInvocationId String
  agentInvocation   AgentInvocation @relation(fields: [agentInvocationId], references: [id], onDelete: Cascade)
  agentTurnId       String?
  agentTurn         AgentTurn?      @relation(fields: [agentTurnId], references: [id], onDelete: SetNull)
  toolUseId         String
  name              String
  input             Json
  output            String?
  outputTruncatedAt Int?
  success           Boolean?
  errorText         String?
  spanId            String          @unique
  parentSpanId      String
  startedAt         DateTime        @default(now())
  endedAt           DateTime?
  durationMs        Int?

  @@unique([agentInvocationId, toolUseId])
  @@index([agentInvocationId, startedAt])
  @@index([name])
  @@map("tool_call")
}

model Retrospective {
  id                  String            @id @default(cuid())
  workflowExecutionId String            @unique
  workflowExecution   WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)
  summary             String?
  bottlenecks         Json              @default("[]")
  recommendations     Json              @default("[]")
  riskFactors         Json              @default("[]")
  stats               Json              @default("{}")
  model               String?
  costUsd             Float?
  createdAt           DateTime          @default(now())

  @@map("retrospective")
}
