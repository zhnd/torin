{
  "name": "@torin/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions development --env-file=../../.env src/server.ts",
    "check": "biome check",
    "check-types": "tsc --noEmit",
    "start": "node dist/server",
    "clean": "node ../../scripts/rm.mjs dist",
    "build": "tsc -b .",
    "generate": "pnpm tsx --conditions development scripts/export-schema.ts",
    "start:migrate:prod": "pnpm --filter @torin/database migrate:deploy && pnpm start"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/fastify": "^3.1.0",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@fastify/cors": "^11.2.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.3",
    "@pothos/plugin-relay": "^4.7.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@torin/database": "workspace:*",
    "@torin/domain": "workspace:*",
    "@torin/shared": "workspace:*",
    "@torin/workflow": "workspace:*",
    "better-auth": "^1.5.6",
    "fastify": "^5.8.4",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
